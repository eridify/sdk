{
    "name": "eridify/sdk",
    "description": "PHP SDK для eridify",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "ord",
        "api",
        "sdk",
        "http-client"
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^6.5 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "vimeo/psalm": "^5.26"
    },
    "autoload": {
        "psr-4": {
            "Eridify\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eridify\\SDK\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "psalm": "psalm --no-cache"
    }
}
